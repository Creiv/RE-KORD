{
  "name": "rekord",
  "description": "RE-KORD — local hub for listening to, organizing, and maintaining a personal music library",
  "author": "RE-KORD",
  "private": true,
  "version": "3.5.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -n srv,vite -c blue,magenta \"node server/index.mjs\" \"vite\"",
    "dev:server": "node server/index.mjs",
    "dev:vite": "vite",
    "dev:app": "concurrently -k -n vite,el -c green,magenta \"vite\" \"wait-on -t 120000 http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "start": "node server/index.mjs",
    "pack": "node scripts/pack-release.mjs server win",
    "pack:linux": "node scripts/pack-release.mjs server linux",
    "pack:android:client": "node scripts/pack-android.mjs",
    "pack:linux:server": "node scripts/pack-release.mjs server linux",
    "pack:linux:client": "node scripts/pack-release.mjs client linux",
    "pack:win:server": "node scripts/pack-release.mjs server win",
    "pack:win:client": "node scripts/pack-release.mjs client win",
    "pack:mac:server": "node scripts/pack-release.mjs server mac",
    "pack:mac:client": "node scripts/pack-release.mjs client mac",
    "ytdlp:fetch": "node scripts/fetch-ytdlp.mjs",
    "cloudflared:fetch": "node scripts/fetch-cloudflared.mjs",
    "pack:win": "node scripts/pack-release.mjs server win",
    "pack:mac": "node scripts/pack-release.mjs server mac",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f rekord"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/core": "^8.4.0",
    "@tanstack/react-virtual": "^3.14.2",
    "archiver": "^7.0.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.rekord.app",
    "productName": "RE-KORD",
    "icon": "public/REKORDlogo.png",
    "copyright": "Copyright RE-KORD",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "dist",
      "public/REKORDlogo.png",
      "electron",
      "server",
      "node_modules"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "public/REKORDlogo.png",
      "target": [
        "AppImage"
      ],
      "category": "Audio"
    },
    "mac": {
      "icon": "public/REKORDlogo.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.music"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "asar": true,
    "asarUnpack": [
      "node_modules",
      "server",
      "dist"
    ],
    "artifactName": "${name}-${version}-${os}-${arch}.${ext}"
  }
}
