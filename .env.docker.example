# Copia in .env accanto a docker-compose.yml e adatta i percorsi.

REKORD_PORT=3001
REKORD_LISTEN_HOST=0.0.0.0

# Cartelle host montate nel container (bind mount — niente copia manuale nel volume Docker).
# Default: cartelle locali al progetto. Per la tua libreria reale, decommenta e imposta il path:
# REKORD_MUSIC_HOST=/home/TUO_UTENTE/Musica/Libreria
REKORD_MUSIC_HOST=./docker-data/music
REKORD_CONFIG_HOST=./docker-data/config

# Opzionale: file cookies YouTube in /config
# REKORD_YTDLP_COOKIES=/config/youtube-cookies.txt
